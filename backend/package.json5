{
    name: 'backend',
    private: true,
    type: 'module',
    scripts: {
        'dev': 'tsx watch src/index.ts',
        'start': 'tsx src/index.ts',

        'code:tsc': 'tsc --noEmit',
        'code:lint': 'oxlint',
        'code:fmt': 'oxfmt',
        'code': 'pnpm code:tsc && pnpm code:lint && pnpm code:fmt',

        'test': 'vitest run',
        'test:watch': 'vitest',
    },
    dependencies: {
        '@hono/node-server': '2.0.2',
        'hono': '4.12.19',
        'pino': '10.3.1',
    },
    devDependencies: {
        '@types/node': '25.8.0',
        'tsx': '4.22.1',
        'typescript': 'catalog:',
        'vitest': 'catalog:',
    },
}
