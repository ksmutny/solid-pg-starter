{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        // target
        "target": "ESNext",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],

        // jsx
        "jsx": "preserve",
        "jsxImportSource": "@solidjs/web",

        // project references (composite projects must emit; we only emit .d.ts into the cache)
        "composite": true,
        "noEmit": false,
        "emitDeclarationOnly": true,
        "outDir": "./node_modules/.cache/tsc/app",
        "tsBuildInfoFile": "./node_modules/.cache/tsc/app.tsbuildinfo"
    },
    "include": ["src"]
}
