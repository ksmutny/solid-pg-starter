{
    name: 'frontend',
    private: true,
    type: 'module',
    scripts: {
        'dev': 'vite --host',
        'build': 'vite build',
        'preview': 'vite preview',

        'code:tsc': 'tsc -b',
        'code:lint': 'oxlint',
        'code:fmt': 'oxfmt',
        'code': 'pnpm code:tsc && pnpm code:lint && pnpm code:fmt',

        'test': 'vitest run',
        'test:watch': 'vitest',
    },
    dependencies: {
        '@solidjs/router': '0.17.0-next.3',
        '@solidjs/web': '2.0.0-beta.13',
        'solid-js': '2.0.0-beta.13',
    },
    devDependencies: {
        'sass-embedded': '1.99.0',
        'typescript': 'catalog:',
        'vite': '8.0.13',
        'vite-plugin-solid': '3.0.0-next.5',
        'vitest': 'catalog:',
    },
}
