{
    name: 'solid-pg-starter',
    description: 'Starter template for SolidJS + Node.js + PostgreSQL projects',
    author: 'Karel Smutny <karel.smutny@outlook.com>',
    private: true,
    engines: {
        node: '>=24',
        pnpm: '>=11',
    },
    scripts: {
        'install:fe': 'pnpm install --filter frontend',
        'install:be': 'pnpm install --filter backend',
        'install:all': 'pnpm install:fe && pnpm install:be',

        'code:fe': 'pnpm --filter frontend code',
        'code:be': 'pnpm --filter backend code',
        'code': 'pnpm code:fe && pnpm code:be',

        'test:fe': 'pnpm --filter frontend test',
        'test:be': 'pnpm --filter backend test',
        'test': 'pnpm test:fe && pnpm test:be',
    },
    devDependencies: {
        'oxfmt': '0.50.0',
        'oxlint': '1.65.0',
    },
}
